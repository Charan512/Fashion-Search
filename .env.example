# ─────────────────────────────────────────────────────────────
# Fashion Retrieval System — Environment Variables Template
# Copy to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────

# ── Pinecone Vector Database ─────────────────────────────────
# Get your API key at: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=fashion-retrieval

# ── Dataset ──────────────────────────────────────────────────
# Subset size for indexing (1000 for dev, 50000 for production)
DATASET_SUBSET_SIZE=1000

# Optional: path to local image dataset (overrides HuggingFace download)
# DATASET_PATH=/path/to/local/fashionpedia/images

# ── Model Device ─────────────────────────────────────────────
# Set to "cpu" if no GPU available (slow for indexing but works for retrieval)
DEVICE=cuda

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
